# Configuração da API - JDE Venda

## Local Development
#EXPO_PUBLIC_API_URL=http://localhost:3000

## Production (Render)
EXPO_PUBLIC_API_URL=https://api-jose-jhbt.onrender.com

## Supabase Configuration (se usar Supabase)
# SUPABASE_PROJECT_REF=seu-project-ref
# SUPABASE_ANON_KEY=sua-anon-key

## Environment
EXPO_PUBLIC_ENV=development

## API Configuration
EXPO_PUBLIC_API_TIMEOUT=15000

## Debug Mode
EXPO_PUBLIC_DEBUG=false

## Features
EXPOSE_PUBLIC_ENABLE_CASH_REGISTER=true
EXPO_PUBLIC_ENABLE_LOCACOES=true
EXPO_PUBLIC_ENABLE_REPORTS=true
